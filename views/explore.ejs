<%- include("partials/header", { title: "Paw Explorer" }) %>

<section class="explore-section">

    <h1>
        <i class="fa-solid fa-paw"></i>
        Paw Explorer
    </h1>

    <p class="explore-subtitle">
        Discover beautiful images and explore everything about this breed.
    </p>

    <div class="breed-profile">

        <div class="breed-image">

            <img src="<%= imageLink %>" alt="<%= breed %>">

        </div>

        <div class="breed-info">

            <h2><%= breed %></h2>

            <p class="breed-desc">

                Browse beautiful photos and uncover every paw branch in the Pawtopia collection.
            </p>

            <div class="breed-highlights">

                <div class="highlight-item">
                    <i class="fa-solid fa-paw"></i>
                    <span>Beautiful breed gallery</span>
                </div>

                <div class="highlight-item">
                    <i class="fa-solid fa-paw"></i>
                    <span>Sub-breeds available to explore</span>
                </div>

            </div>

        </div>

    </div>

    <div class="explore-action">

        <a href="/subbreeds/<%= breed %>" class="branch-btn">

            <i class="fa-solid fa-code-branch"></i>

            Explore Sub-Breeds

        </a>

    </div>

</section>

<%- include("partials/footer") %>