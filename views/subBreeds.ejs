<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🐶🌿 Paw Branches</title>
</head>
<body>
    <h1>🐶🌿 Paw Branches</h1>
    <h2>Breed - <%=breed%></h2>
    <hr>
    <%if (sub.length === 0){%>
        <p>🐾 No Paw Branches found for this breed.</p>
        <br>
        <hr>
        <a href="/breeds">Back to Breed Atlas</a>
    <%}else{%>
        <%for (let key of sub) {%>
            <a href="/subbreeds?name=<%=breed%>&sub=<%=key%>"><%=key%></a>
            <br>
        <%}%>
        <br>
        <hr>
        <a href="/breeds">🐾Back to Breed Atlas</a>
    <%}%>
    <br>
    <a href="/">🏠 Back to Home</a>
</body>
</html>